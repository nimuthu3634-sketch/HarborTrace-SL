rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return isSignedIn() ? userDoc().data.role : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isHarborOfficer() {
      return userRole() == 'harbor_officer';
    }

    function isFisherman() {
      return userRole() == 'fisherman';
    }

    function isBuyer() {
      return userRole() == 'buyer';
    }

    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    match /trips/{tripId} {
      allow read: if isSignedIn();
      allow create: if isFisherman() && request.resource.data.fishermanId == request.auth.uid;
      allow update: if isAdmin() || isHarborOfficer();
      allow delete: if isAdmin();
    }

    match /landingIntakes/{intakeId} {
      allow read: if isSignedIn();
      allow create: if isFisherman() && request.resource.data.fishermanId == request.auth.uid;
      allow update: if isAdmin() || isHarborOfficer();
      allow delete: if isAdmin();
    }

    match /incidentAlerts/{alertId} {
      allow read: if isSignedIn();
      allow create: if isFisherman() && request.resource.data.fishermanId == request.auth.uid;
      allow update: if isAdmin() || isHarborOfficer();
      allow delete: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if isSignedIn() && (isBuyer() || isHarborOfficer() || isAdmin() || isFisherman());
      allow create, update, delete: if isAdmin() || isHarborOfficer();
    }

    match /harborNotices/{noticeId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() || isHarborOfficer();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
