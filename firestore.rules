rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Common auth + role helpers ---------------------------------------------------------
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userRole() {
      return signedIn() ? userDoc(request.auth.uid).data.role : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isOfficer() {
      return userRole() == 'harbor_officer';
    }

    function isFisherman() {
      return userRole() == 'fisherman';
    }

    function isBuyer() {
      return userRole() == 'buyer';
    }

    function hasOnlyKeys(allowedKeys) {
      return request.resource.data.keys().hasOnly(allowedKeys);
    }

    function unchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // ---- User profile + role controls (prevents client-side role escalation) ---------------
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isOfficer() || isAdmin());

      allow create: if signedIn()
                    && request.auth.uid == uid
                    && request.resource.data.uid == uid
                    && request.resource.data.role in ['fisherman', 'harbor_officer', 'buyer', 'admin']
                    && hasOnlyKeys(['uid', 'role', 'displayName', 'phone', 'createdAt']);

      allow update: if signedIn() && (
        // Users can edit their own profile fields, but never their identity/role fields.
        (request.auth.uid == uid
          && unchanged('uid')
          && unchanged('role'))
        // Admin retains broad access, still with immutable uid guard.
        || (isAdmin() && unchanged('uid'))
      );

      allow delete: if isAdmin();
    }

    // ---- Trip records -----------------------------------------------------------------------
    match /trips/{tripId} {
      function validTripStatus(status) {
        return status in ['planned', 'active', 'completed', 'overdue', 'emergency'];
      }

      allow read: if signedIn() && (
        isAdmin()
        || isOfficer()
        || (isFisherman() && resource.data.fishermanUid == request.auth.uid)
      );

      allow create: if isFisherman()
                    && request.resource.data.fishermanUid == request.auth.uid
                    && request.resource.data.createdByUid == request.auth.uid
                    && request.resource.data.createdByRole == 'fisherman'
                    && validTripStatus(request.resource.data.status)
                    && hasOnlyKeys([
                      'vesselId',
                      'departureHarborId',
                      'destinationZone',
                      'crewCount',
                      'departureTime',
                      'expectedReturnTime',
                      'emergencyContact',
                      'notes',
                      'fishermanUid',
                      'status',
                      'createdByUid',
                      'createdByRole',
                      'createdAt',
                      'updatedAt',
                      'lastStatusChangedAt'
                    ]);

      allow update: if signedIn() && (
        (isFisherman()
          && resource.data.fishermanUid == request.auth.uid
          && request.resource.data.fishermanUid == resource.data.fishermanUid
          && request.resource.data.createdByUid == resource.data.createdByUid
          && request.resource.data.createdByRole == resource.data.createdByRole
          && unchanged('vesselId')
          && unchanged('departureHarborId')
          && unchanged('destinationZone')
          && unchanged('crewCount')
          && unchanged('departureTime')
          && unchanged('expectedReturnTime')
          && unchanged('emergencyContact')
          && validTripStatus(request.resource.data.status))
        || isOfficer()
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ---- Incident alerts --------------------------------------------------------------------
    match /alerts/{alertId} {
      allow read: if signedIn() && (
        isAdmin()
        || isOfficer()
        || (isFisherman() && resource.data.fishermanUid == request.auth.uid)
      );

      allow create: if isFisherman() && request.resource.data.fishermanUid == request.auth.uid;

      allow update: if signedIn() && (
        // Fisherman can update own alert details, but not verification/workflow fields.
        (isFisherman()
          && resource.data.fishermanUid == request.auth.uid
          && request.resource.data.fishermanUid == resource.data.fishermanUid
          && unchanged('verificationStatus')
          && unchanged('resolvedByOfficerUid')
          && unchanged('resolvedAt'))
        || isOfficer()
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ---- Landing submissions ----------------------------------------------------------------
    match /landings/{landingId} {
      allow read: if signedIn() && (
        isAdmin()
        || isOfficer()
        || (isFisherman() && resource.data.fishermanUid == request.auth.uid)
      );

      allow create: if isFisherman()
                    && request.resource.data.fishermanUid == request.auth.uid
                    && request.resource.data.submissionStatus in ['draft', 'submitted'];

      allow update: if signedIn() && (
        // Fisherman may revise own submission, not protected verification fields.
        (isFisherman()
          && resource.data.fishermanUid == request.auth.uid
          && request.resource.data.fishermanUid == resource.data.fishermanUid
          && unchanged('verificationStatus')
          && unchanged('verifiedByOfficerUid')
          && unchanged('verifiedAt'))
        // Harbor officers/admin can run intake/verification workflows.
        || isOfficer()
        || isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ---- Batch traceability (buyer-safe reads only) -----------------------------------------
    match /batches/{batchId} {
      allow read: if signedIn() && (
        isAdmin()
        || isOfficer()
        || (isFisherman() && resource.data.fishermanUid == request.auth.uid)
        || (isBuyer() && resource.data.buyerSafe == true)
      );

      allow create, update: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // ---- Operational/supporting collections -------------------------------------------------
    match /vessels/{vesselId} {
      allow read: if signedIn() && (isAdmin() || isOfficer() || isFisherman());
      allow create, update: if signedIn() && (isAdmin() || isOfficer());
      allow delete: if isAdmin();
    }

    match /harbors/{harborId} {
      allow read: if signedIn() && (isAdmin() || isOfficer() || isFisherman() || isBuyer());
      allow create, update, delete: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if signedIn() && (isAdmin() || isOfficer() || isFisherman() || isBuyer());
      allow create, update: if isAdmin() || isOfficer();
      allow delete: if isAdmin();
    }

    // ---- Admin-only analytics and immutable audit logs --------------------------------------
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /analytics/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ---- Explicit default deny ---------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
